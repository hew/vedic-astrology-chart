{
  "name": "vedic-astrology-chart",
  "version": "1.0.0",
  "description": "Beautiful Vedic (Jyotish) astrology chart component for React",
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/hew/vedic-astrology-chart.git"
  },
  "bugs": {
    "url": "https://github.com/hew/vedic-astrology-chart/issues"
  },
  "homepage": "https://github.com/hew/vedic-astrology-chart#readme",
  "scripts": {
    "build": "vite build",
    "prepublishOnly": "npm run build",
    "dev": "vite",
    "preview": "vite preview",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "format:src": "prettier --write src/**/*.{ts,tsx,js,jsx,json,md}",
    "check": "bun run lint && bun run format:check",
    "fix": "bun run lint:fix && bun run format"
  },
  "keywords": [
    "vedic",
    "astrology",
    "jyotish",
    "chart",
    "horoscope",
